<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:tools="http://schemas.android.com/tools"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             tools:context=".FragmentMaintenance"
             android:layout_marginTop="@dimen/title_height"
             tools:layout_margin="0dp">


    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/content_layout_margin"
            android:gravity="center_horizontal">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                    style="@style/TitleTextViewStyle"
                    android:text="@string/barcode_scan_pos"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="center_horizontal">

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true">

                        <!--第一点位置-->
                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/first_point_x" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=":"
                                />

                        <EditText
                                android:id="@+id/et_first_point_x"
                                android:layout_width="@dimen/et_input_layout_width"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:inputType="numberDecimal"
                                android:backgroundTint="@color/white"
                                />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mm"
                                />

                        <info.hoang8f.widget.FButton
                                style="@style/ButtonStyle"
                                android:id="@+id/btn_first_point_x"
                                android:text="@string/execute"
                                android:layout_marginLeft="5dp"/>

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/first_point_y"
                                android:layout_marginLeft="30dp"
                                />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=":"
                                />

                        <EditText
                                android:id="@+id/et_first_point_y"
                                android:layout_width="@dimen/et_input_layout_width"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:inputType="numberDecimal"
                                android:backgroundTint="@color/white"
                                />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mm"
                                />

                        <info.hoang8f.widget.FButton
                                style="@style/ButtonStyle"
                                android:id="@+id/btn_first_point_y"
                                android:text="@string/execute"
                                android:layout_marginLeft="5dp"/>
                    </LinearLayout>

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginTop="10dp">

                        <!--x步长-->
                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/step_length_x"
                                />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=":"
                                />

                        <EditText
                                android:id="@+id/et_step_length_x"
                                android:layout_width="@dimen/et_input_layout_width"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:inputType="numberDecimal"
                                android:backgroundTint="@color/white"
                                />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mm"
                                />

                        <!--y步长-->
                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/step_length_y"
                                android:layout_marginLeft="150dp"
                                />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=":"
                                />

                        <EditText
                                android:id="@+id/et_step_length_y"
                                android:layout_width="@dimen/et_input_layout_width"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:inputType="numberDecimal"
                                android:backgroundTint="@color/white"
                                />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mm"
                                />
                    </LinearLayout>

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:layout_gravity="center_horizontal">

                        <info.hoang8f.widget.FButton
                                style="@style/ButtonStyle"
                                android:id="@+id/btn_left_1mm"
                                android:text="@string/left_1mm"
                                android:layout_gravity="center_vertical"/>

                        <info.hoang8f.widget.FButton
                                style="@style/ButtonStyle"
                                android:id="@+id/btn_right_1mm"
                                android:layout_marginLeft="20dp"
                                android:text="@string/right_1mm"
                                android:layout_gravity="center_vertical"/>

                        <info.hoang8f.widget.FButton
                                style="@style/ButtonStyle"
                                android:id="@+id/btn_top_1mm"
                                android:layout_marginLeft="20dp"
                                android:text="@string/top_1mm"
                                android:layout_gravity="center_vertical"/>

                        <info.hoang8f.widget.FButton
                                style="@style/ButtonStyle"
                                android:id="@+id/btn_bottom_1mm"
                                android:layout_marginLeft="20dp"
                                android:text="@string/bottom_1mm"
                                android:layout_gravity="center_vertical"/>

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/result"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="@dimen/separator_layout_margin_left_right"/>

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:text=":"/>

                        <TextView
                                android:id="@+id/tv_scan_result"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:text=""/>
                    </LinearLayout>

                </LinearLayout>

                <info.hoang8f.widget.FButton
                        style="@style/ButtonStyle"
                        android:id="@+id/btn_save"
                        android:layout_marginLeft="30dp"
                        android:text="@string/save"
                        android:layout_gravity="center_vertical"/>

                <info.hoang8f.widget.FButton
                        style="@style/ButtonStyle"
                        android:id="@+id/btn_scan"
                        android:text="@string/scan"
                        android:layout_marginLeft="20dp"
                        android:layout_gravity="center_vertical"/>
            </LinearLayout>
        </LinearLayout>

        <!--点位置按钮-->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:gravity="center_vertical"
                android:layout_marginTop="100dp"
                android:layout_marginLeft="58dp">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/to_this_pos"
                    android:layout_gravity="center_horizontal"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:layout_gravity="center_horizontal"/>
        </LinearLayout>

        <GridLayout
                android:id="@+id/layout_btn_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
        </GridLayout>
    </LinearLayout>

</FrameLayout>