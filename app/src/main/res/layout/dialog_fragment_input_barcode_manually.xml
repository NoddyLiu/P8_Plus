<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:tools="http://schemas.android.com/tools"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             tools:context="com.superh2.p8.dialogs.DialogFragment_Input_Barcode_Manually">

    <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="20dp">

        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal">
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/default_textSize"
                    android:textColor="@color/red"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/info_input_barcode_manually_1"/>

            <TextView
                    android:id="@+id/tv_slide_pos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/default_textSize"
                    android:textColor="@color/red"
                    android:layout_gravity="center_horizontal"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/default_textSize"
                    android:textColor="@color/red"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/info_input_barcode_manually_2"/>
        </LinearLayout>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_empty_value_indicates_slide_not_exist"
                android:textColor="@color/red"
                android:layout_gravity="center_horizontal"/>

        <EditText
                android:id="@+id/et_input_barcode_manually"
                android:layout_width="@dimen/params_group_edittext_layout_width"
                android:layout_height="wrap_content"
                android:selectAllOnFocus="false"
                android:inputType="textFilter"
                android:maxLines="1"
                android:textCursorDrawable="@drawable/shape_cursor"
                android:textSize="@dimen/default_textSize"
                android:layout_gravity="center_horizontal"
                android:gravity="center_horizontal"
                android:hint="@string/info_input_barcode_manually"
                android:layout_marginTop="10dp"/>

        <com.superh2.library.myView.FloatingKeyboardViewNotDragable
                android:id="@+id/keyboardview"
                android:layout_width="@dimen/soft_keyboard_width"
                android:layout_height="@dimen/soft_keyboard_height"
                android:focusable="true"
                android:visibility="gone"
                android:focusableInTouchMode="true"
                android:keyTextColor="@color/black"
                android:keyBackground="@drawable/selector_keyboard"
                android:keyTextSize="30sp"
                android:shadowRadius="0.0"
                android:background="@android:color/transparent"
                android:elevation="1dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="-50dp"/>
    </LinearLayout>
</FrameLayout>
