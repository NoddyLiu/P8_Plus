<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:tools="http://schemas.android.com/tools"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             tools:context=".FragmentMaintenance"
             android:layout_marginTop="@dimen/title_height"
             tools:layout_margin="0dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginLeft="@dimen/content_layout_margin"
            android:layout_marginRight="@dimen/content_layout_margin"
            android:gravity="center_horizontal">

        <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_height="@dimen/params_group_tab_layout_height"
                android:layout_width="match_parent"
                android:layout_marginLeft="@dimen/content_layout_margin"
                android:layout_marginRight="@dimen/content_layout_margin"
                app:tabIndicatorHeight="0dp"
                app:tabIndicatorColor="@color/fbutton_default_color"
                app:tabMode="scrollable">
        </com.google.android.material.tabs.TabLayout>

        <FrameLayout
                android:id="@+id/framelayout_method_parameters_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="-40dp">

        </FrameLayout>

    </LinearLayout>
</FrameLayout>