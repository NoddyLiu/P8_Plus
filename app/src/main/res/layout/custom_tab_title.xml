<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/params_group_tab_layout_height"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp">
    <TextView
            android:id="@+id/tv_tab_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAllCaps="false"
            android:text="1.测试的"
            android:textSize="@dimen/params_group_tab_textSize"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="@drawable/selector_tab_title"/>

    <ImageView
            android:id="@+id/imageview_tab_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_tab_title"
            android:background="@drawable/selector_tab_indicator"
            android:layout_centerHorizontal="true"
            android:padding="0dp"
            android:layout_marginTop="-20dp"/>
</RelativeLayout>
