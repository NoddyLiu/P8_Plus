<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="35dp"
        tools:context=".FragmentMaintenance"
        tools:layout_margin="0dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/content_layout_margin"
                android:gravity="center_horizontal"
                android:orientation="vertical">

            <GridLayout
                    style="@style/GridLayoutStyle"
                    android:layout_width="match_parent"
                    android:layout_marginTop="30dp"
                    android:columnCount="2"
                    android:rowCount="4">

                <LinearLayout
                        style="@style/GridCellStyleGeneralParamsTitle"
                        android:layout_columnSpan="2"
                        android:background="@color/appBackground">

                    <TextView
                            style="@style/TitleTextViewStyle"
                            android:text="@string/general_parameters" />
                </LinearLayout>

                <!--Tip头预吸空气（吸液前）-->
                <LinearLayout style="@style/GridCellStyleGeneralParams"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_additional_air_in_tip_before_absorb" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/zero_20"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_additional_air_in_tip_before_absorb"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_ul" />
                </LinearLayout>

                <!--Tip头隔离空气（吸液后）-->
                <LinearLayout style="@style/GridCellStyleGeneralParams"
                        android:layout_width="0dp"
                        android:layout_columnWeight="1">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_additional_air_in_tip_after_absorb" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/zero_20"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_additional_air_in_tip_after_absorb"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_ul" />
                </LinearLayout>

                <!--Tip头隔离空气（喷液后）-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_additional_air_in_tip_after_dispense" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/zero_20"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_additional_air_in_tip_after_dispense"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_ul" />
                </LinearLayout>

                <!--样品吹打次数-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_number_of_sample_stir" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/one_10"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_number_of_sample_stir"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_times" />
                </LinearLayout>

                <!--样品吹打体积-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_volumn_of_sample_stir" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/ten_180"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_volumn_of_sample_stir"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_ul" />
                </LinearLayout>

                <!--样品吹打速度-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_speed_of_sample_stir" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/one_10"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_speed_of_sample_stir"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />
                </LinearLayout>

                <!--预喷雾时间-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_gravity="center_vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_pre_spray_time"/>

                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_pre_spray_time"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_second" />
                </LinearLayout>

                <!--预喷雾加液步数-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_gravity="center_vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_pre_spray_liquid_addition"/>

                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_pre_spray_liquid_addition"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/unit_step" />
                </LinearLayout>

                <!--预喷雾加液反抽步数-->
<!--                <LinearLayout style="@style/GridCellStyleGeneralParams">-->

<!--                    <LinearLayout-->
<!--                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:orientation="vertical"-->
<!--                            android:layout_gravity="center_vertical">-->

<!--                        <TextView-->
<!--                                android:layout_width="wrap_content"-->
<!--                                android:layout_height="wrap_content"-->
<!--                                android:text="@string/general_params_pre_spray_liquid_addition_reverse"/>-->

<!--                    </LinearLayout>-->

<!--                    <TextView-->
<!--                            android:layout_width="wrap_content"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:text=":" />-->

<!--                    <EditText-->
<!--                            android:id="@+id/et_pre_spray_liquid_addition_reverse"-->
<!--                            android:layout_width="@dimen/et_input_layout_width"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:gravity="center_horizontal"-->
<!--                            android:inputType="number" />-->

<!--                    <TextView-->
<!--                            android:layout_width="wrap_content"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:text="@string/unit_step" />-->
<!--                </LinearLayout>-->

                <!--喷雾加液速度-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/general_params_spray_liquid_addition_speed"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_spray_liquid_addition_init_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_init_speed"/>

                    <EditText
                            android:id="@+id/et_spray_liquid_addition_target_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_target_speed"/>

                    <EditText
                            android:id="@+id/et_spray_liquid_addition_accelerated_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_accelerated_speed"/>
                </LinearLayout>

                <!--试管底座是否手动检测-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/tube_base_manual_check" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginRight="50dp"
                            android:text=":" />

                    <com.suke.widget.SwitchButton
                            android:id="@+id/switchbtn_tube_base_manual_check"
                            android:layout_width="@dimen/switchbutton_layout_width"
                            android:layout_height="@dimen/switchbutton_layout_height"
                            android:layout_gravity="center_vertical"
                            android:layout_marginLeft="10dp"
                            app:sb_show_indicator="false" />
                </LinearLayout>

                <!--扫码完毕后是否直接运行-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/run_immediately_after_scanned" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginRight="50dp"
                            android:text=":" />

                    <com.suke.widget.SwitchButton
                            android:id="@+id/switchbtn_run_immediately_after_scanned"
                            android:layout_width="@dimen/switchbutton_layout_width"
                            android:layout_height="@dimen/switchbutton_layout_height"
                            android:layout_gravity="center_vertical"
                            android:layout_marginLeft="10dp"
                            app:sb_show_indicator="false" />
                </LinearLayout>

                <!--喷液最大速度-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/general_params_dispense_speed_max"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_dispense_speed_max_init_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_init_speed"/>

                    <EditText
                            android:id="@+id/et_dispense_speed_max_target_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_target_speed"/>

                    <EditText
                            android:id="@+id/et_dispense_speed_max_accelerated_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_accelerated_speed"/>
                </LinearLayout>

                <!--喷雾时Y轴最大速度-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/general_params_y_speed_max_when_spraying"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_y_speed_max_when_spraying_init_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_init_speed"/>

                    <EditText
                            android:id="@+id/et_y_speed_max_when_spraying_target_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_target_speed"/>

                    <EditText
                            android:id="@+id/et_y_speed_max_when_spraying_accelerated_speed"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number"
                            android:hint="@string/general_params_accelerated_speed"/>
                </LinearLayout>

                <!--二维码扫码长度-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_qr_code_scan_length" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/one_20"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_qr_code_scan_length"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />
                </LinearLayout>

                <!-- 枪头状态检测报警-->
                <LinearLayout
                        style="@style/GridCellStyleGeneralParams"
                        android:gravity="center_vertical">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/general_params_tip_check_alarm" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text=":" />

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/off"/>

                        <com.suke.widget.SwitchButton
                                android:id="@+id/switchbtn_alarm_tip_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                app:sb_show_indicator="false" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/on"/>
                    </LinearLayout>
                </LinearLayout>

                <!--气流速度-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_airflow_speed" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/one_8"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_speed_air_flow"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />
                </LinearLayout>

                <!--分散指数-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_dispersancy_index" />

                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text=":" />

                    <GridLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_1"
                                style="@style/ButtonStyleSmall"
                                android:layout_width="41dp"
                                android:layout_gravity="center_vertical"
                                android:text="1" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_2"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="1"
                                android:text="2" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_3"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="2"
                                android:text="3" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_4"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="3"
                                android:text="4" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_5"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="4"
                                android:text="5" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_6"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="5"
                                android:text="6" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_7"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="6"
                                android:text="7" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_8"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="7"
                                android:text="8" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_9"
                                style="@style/ButtonStyleSmall"
                                android:layout_gravity="center_vertical"
                                android:layout_row="0"
                                android:layout_column="8"
                                android:text="9" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_dispersancy_index_10"
