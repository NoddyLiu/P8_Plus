                <!--开门报警（运行中开门弹窗报警）-->
                <LinearLayout
                        style="@style/GridCellStyleGeneralParams"
                        android:gravity="center_vertical">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="@string/general_params_door_open_alarm" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text=":" />

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/off"/>

                        <com.suke.widget.SwitchButton
                                android:id="@+id/switchbtn_alarm_door"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                app:sb_show_indicator="false" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/on"/>
                    </LinearLayout>
                </LinearLayout>

                <!--温湿度稳定差值区间（用于温湿度稳定n分钟后，程序自启动）-->
                <LinearLayout style="@style/GridCellStyleGeneralParams">

                    <LinearLayout
                            android:layout_width="@dimen/general_params_tv_title_item_layout_width"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/general_params_humiture_stability_threshold" />

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:text="@string/zeroP1_1"
                                android:textSize="@dimen/tv_explain_info_textSize" />
                    </LinearLayout>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":" />

                    <EditText
                            android:id="@+id/et_humiture_stability_threshold"
                            android:layout_width="@dimen/et_input_layout_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:inputType="number" />
                </LinearLayout>

                <!--重置、保存按钮-->
                <LinearLayout
                        style="@style/GridCellStyleGeneralParams"
                        android:gravity="center_horizontal">

                    <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_remote_maintenance"
                                style="@style/ButtonStyle"
                                android:layout_gravity="center_vertical"
                                android:text="@string/general_params_remote_maintenance" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_reset"
                                style="@style/ButtonStyle"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="30dp"
                                android:text="@string/reset" />

                        <info.hoang8f.widget.FButton
                                android:id="@+id/btn_save"
                                style="@style/ButtonStyle"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="30dp"
                                android:text="@string/save" />
                    </LinearLayout>
                </LinearLayout>
            </GridLayout>
        </LinearLayout>

    <!--Next-->
    <info.hoang8f.widget.FButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/btn_next"
